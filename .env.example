# =============================================================
# Lead-Gen Pipeline — Environment Variables Template
# Copy this file to .env and fill in your actual keys
# =============================================================

# --- LLM / Embeddings (Gemini) ---
# Gemini API Key used for Tier-2 validation and Response Generation
GEMINI_API_KEY=your_gemini_api_key_here

# --- Reddit (OAuth2 for reading & posting) ---
# Required for Reddit ingestion and posting replies. Obtain from reddit.com/prefs/apps.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=LeadGenPoC/0.1 by your_reddit_username

# --- YouTube API & OAuth ---
# YOUTUBE_API_KEY: General search and read operations (YouTube Data API v3)
YOUTUBE_API_KEY=your_youtube_api_key_here
# YOUTUBE_OAUTH_TOKEN: Temporary OAuth2 token required for authenticated comment posting
YOUTUBE_OAUTH_TOKEN=your_youtube_oauth_token_here

# --- X / Twitter API v2 ---
# OAuth 1.0a & OAuth 2.0 credentials for Twitter search and posting
X_BEARER_TOKEN=your_x_bearer_token
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_token_secret

# --- Application Config ---
TIER2_THRESHOLD=85
DEDUP_TTL_HOURS=72
DATABASE_URL=sqlite:///./data/leadgen.db
